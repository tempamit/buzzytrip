{
  "name": "buzzytrip",
  "version": "0.0.0",
  "private": true,
  "description": "BuzzyTrip travel intelligence and itinerary platform",
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=22 <23"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.12"
    },
    "next": {
      "postcss": "8.5.15"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "node scripts/run-workspaces.mjs build",
    "content:generate-mvp": "node --env-file-if-exists=.env --import tsx apps/worker/src/content/generate-mvp.ts",
    "db:backup": "node scripts/database-backup.mjs",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate --config packages/database/drizzle.config.ts",
    "db:migrate": "tsx packages/database/src/migrate.ts",
    "db:restore": "node scripts/database-restore.mjs",
    "db:seed": "tsx packages/database/src/seed.ts",
    "db:up": "docker compose up -d database",
    "db:verify-model-quota": "node scripts/verify-model-quota.mjs",
    "db:verify-catalog": "node scripts/verify-destination-catalog.mjs",
    "db:verify-drafts": "node scripts/verify-draft-persistence.mjs",
    "db:verify-trends": "node scripts/verify-trend-storage.mjs",
    "dev": "turbo run dev --parallel",
    "deploy:build": "docker compose -f compose.coolify.yaml build",
    "deploy:config": "docker compose -f compose.coolify.yaml config --quiet",
    "deploy:smoke": "node scripts/deploy-smoke.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint scripts eslint.config.mjs --max-warnings=0 && node scripts/run-workspaces.mjs lint",
    "media:dry-run": "node --env-file-if-exists=.env --import tsx apps/worker/src/media/dry-run.ts",
    "research:dry-run": "tsx apps/worker/src/research/dry-run.ts",
    "typecheck": "node scripts/run-workspaces.mjs typecheck",
    "test": "node scripts/run-workspaces.mjs test",
    "trend:dry-run": "tsx apps/worker/src/trends/dry-run.ts",
    "check": "prettier --check . && eslint scripts eslint.config.mjs --max-warnings=0 && node scripts/run-workspaces.mjs lint && node scripts/run-workspaces.mjs typecheck && node scripts/run-workspaces.mjs test && node scripts/run-workspaces.mjs build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "turbo": "2.9.18",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
